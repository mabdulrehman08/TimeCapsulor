# Copy to backend/.env and fill in. The real .env is gitignored — never commit it.

# Vapi private (server) API key — from the Vapi dashboard.
# Used to re-fetch a call while waiting for slow recording URLs (e.g. video).
VAPI_API_KEY=

# Optional: if you set a Server URL secret in Vapi, put it here so the
# backend can verify the X-Vapi-Secret header on incoming webhooks.
VAPI_WEBHOOK_SECRET=

# Where downloaded session recordings are stored. Default: backend/data
DATA_DIR=
